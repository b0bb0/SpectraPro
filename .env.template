# ── SpectraPRO — Environment Configuration ───────────────────────────
# Copy this file to .env and fill in the values below.
#
#   cp .env.template .env
#   nano .env            # or run ./scripts/setup-docker.sh to auto-generate secrets
#
# Required values are marked with [REQUIRED].
# Optional values have sensible defaults — leave blank to use them.
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=spectra_platform
POSTGRES_USER=spectra
POSTGRES_PASSWORD=               # [REQUIRED] Generate: openssl rand -base64 32

# ── JWT Authentication ───────────────────────────────────────────────
JWT_SECRET=                      # [REQUIRED] Generate: openssl rand -base64 48
JWT_EXPIRES_IN=24h

# ── Backend ──────────────────────────────────────────────────────────
# FRONTEND_URL is used for CORS. Set to the URL users access in their browser.
# Include the port if not 80/443 (e.g., http://192.168.1.50:3005).
FRONTEND_URL=http://localhost
LOG_LEVEL=info

# ── Frontend (build-time args) ───────────────────────────────────────
# Leave NEXT_PUBLIC_API_URL empty to use relative URLs (recommended for Docker/Caddy).
# Only set it for split deployments where frontend and backend are on different hosts.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=http://localhost

# ── AI Analysis (optional — leave empty to disable) ─────────────────
# To enable: docker compose --profile ai up -d
OLLAMA_API_URL=
OLLAMA_MODEL=
OLLAMA_TIMEOUT=120000
AI_ANALYSIS_ENABLED=false

# ── Scanner API (optional) ──────────────────────────────────────────
# API key for the Python scanner service. Leave empty to disable auth.
SPECTRA_API_KEY=
