# ── SpectraPRO — Environment Configuration ───────────────────────────
# Copy this file to .env and fill in the values below.
#
#   cp .env.template .env
#   nano .env            # or use setup-docker.sh to auto-generate secrets
#
# Required values are marked with [REQUIRED].
# Optional values have sensible defaults — leave blank to use them.
# ─────────────────────────────────────────────────────────────────────

# ── Host Address ─────────────────────────────────────────────────────
# The hostname or IP where SpectraPRO is accessed from browsers.
# Used to build FRONTEND_URL, NEXT_PUBLIC_API_URL, NEXT_PUBLIC_APP_URL.
# Examples: localhost, 192.168.1.50, spectra.example.com
HOST_ADDRESS=localhost

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=spectra_platform
POSTGRES_USER=spectra
POSTGRES_PASSWORD=               # [REQUIRED] Generate: openssl rand -base64 32

# ── JWT Authentication ───────────────────────────────────────────────
JWT_SECRET=                      # [REQUIRED] Generate: openssl rand -base64 48
JWT_EXPIRES_IN=24h

# ── Backend ──────────────────────────────────────────────────────────
# These are derived from HOST_ADDRESS above. Override only if needed.
FRONTEND_URL=http://${HOST_ADDRESS}
LOG_LEVEL=info

# ── Frontend (build-time args) ───────────────────────────────────────
# Leave empty to use relative URLs (recommended for Docker/Caddy).
# Set these only for split deployments where frontend != backend host.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=http://${HOST_ADDRESS}

# ── AI Analysis (optional — leave empty to disable) ─────────────────
# To enable: docker compose --profile ai up -d
OLLAMA_API_URL=
OLLAMA_MODEL=
OLLAMA_TIMEOUT=120000
AI_ANALYSIS_ENABLED=false

# ── Scanner API (optional) ──────────────────────────────────────────
# API key for the Python scanner service. Leave empty to disable auth.
SPECTRA_API_KEY=
