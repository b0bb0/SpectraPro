{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Spectra Platform Frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd platform/frontend && npm run dev -- -p 3003"],
      "port": 3003
    },
    {
      "name": "Spectra Platform Backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd platform/backend && npm run dev"],
      "port": 5001
    },
    {
      "name": "Spectra Scanner API",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd src/api && python3 app.py"],
      "port": 5000
    },
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "docker-compose.dev.yml", "up", "-d"],
      "port": 5432
    }
  ]
}
