# ── Spectra Platform — Production Environment ───────────────────────
# Copy this file to .env and fill in real values before deploying.
#
#   cp .env.production .env
#   # Edit .env with real secrets
#   docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=spectra_platform
POSTGRES_USER=spectra
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ── JWT Authentication ──────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=24h

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend Build Args (baked at Docker build time) ─────────────
# Must match the public URL users access in the browser.
# Use the Droplet IP until DNS is configured, then switch to domain.
NEXT_PUBLIC_API_URL=http://CHANGE_ME_DROPLET_IP
NEXT_PUBLIC_APP_URL=http://CHANGE_ME_DROPLET_IP

# ── Backend CORS ──────────────────────────────────────────────────
# Must exactly match the browser Origin header (no trailing slash).
FRONTEND_URL=http://CHANGE_ME_DROPLET_IP

# ── AI Analysis (optional — leave empty to disable) ────────────────
OLLAMA_API_URL=
OLLAMA_MODEL=
OLLAMA_TIMEOUT=120000
AI_ANALYSIS_ENABLED=false
