# ── Spectra Platform — Production Environment ───────────────────────
# Copy this file to .env and fill in real values before deploying.
#
#   cp .env.production .env
#   # Edit .env with real secrets
#   docker compose -f docker-compose.production.yml up -d
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=spectra_platform
POSTGRES_USER=spectra
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ── JWT Authentication ──────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=24h

# ── Public URLs ─────────────────────────────────────────────────────
# Set these to your live server domain (used by backend CORS + frontend API calls)
FRONTEND_URL=https://spectrapro.ai
NEXT_PUBLIC_API_URL=https://spectrapro.ai
NEXT_PUBLIC_APP_URL=https://spectrapro.ai

# ── Docker Images (override to pin a specific SHA tag) ──────────────
# BACKEND_IMAGE=ghcr.io/b0bb0/spectrapro-backend:latest
# FRONTEND_IMAGE=ghcr.io/b0bb0/spectrapro-frontend:latest
# SCANNER_IMAGE=ghcr.io/b0bb0/spectrapro-scanner:latest

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── AI Analysis (optional — leave empty to disable) ────────────────
OLLAMA_API_URL=
OLLAMA_MODEL=
OLLAMA_TIMEOUT=120000
AI_ANALYSIS_ENABLED=false
