# ── Spectra Platform — Caddy Reverse Proxy ──────────────────────────
# To enable HTTPS:
#   1. Set SITE_ADDRESS=yourdomain.com in .env
#   2. Ensure ports 80+443 are open (Caddy handles Let's Encrypt automatically)
#   3. Rebuild: docker compose -f docker-compose.prod.yml up -d --build caddy
#
# Default: HTTP-only on port 80 (when SITE_ADDRESS is not set)
# ─────────────────────────────────────────────────────────────────────

{$SITE_ADDRESS::80} {
	# ── API & WebSocket ─────────────────────────────────────────────
	handle /api/* {
		reverse_proxy backend:5001
	}

	handle /ws {
		reverse_proxy backend:5001
	}

	handle /health {
		reverse_proxy backend:5001
	}

	# ── Frontend (catch-all) ────────────────────────────────────────
	handle {
		reverse_proxy frontend:3000
	}

	# ── Security headers ───────────────────────────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# ── Logging ────────────────────────────────────────────────────
	log {
		output file /data/logs/access.log {
			roll_size 100mb
			roll_keep 5
		}
	}
}
