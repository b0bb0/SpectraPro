# Database
DATABASE_URL="postgresql://spectra:spectra@localhost:5432/spectra_platform"

# Server
PORT=5001
NODE_ENV=development

# JWT Authentication
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRES_IN="24h"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3001"

# Logging
LOG_LEVEL="info"

# Ollama AI Analysis Configuration
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=hf.co/mlabonne/Meta-Llama-3.1-8B-Instruct-abliterated:BF16
OLLAMA_TIMEOUT=120000
AI_ANALYSIS_ENABLED=true

# Nuclei Configuration
NUCLEI_TEMPLATES_PATH=/path/to/nuclei-templates

# Reconnaissance Tools Configuration
NMAP_PATH=/opt/homebrew/bin/nmap
FEROXBUSTER_PATH=/opt/homebrew/bin/feroxbuster
WORDLIST_PATH=/path/to/wordlists/raft-medium-directories.txt
